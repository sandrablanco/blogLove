---
const {title} = Astro.props
---

<html lang="es">
<head>
<meta charset="utf-8" />
<link rel="icon" type="image/png" href="https://res.cloudinary.com/du5e2crvt/image/upload/v1777023653/Captura_de_pantalla_2026-04-24_114038_ryb6du.png" />
<meta name="viewport" content="width=device-width" />
<title>{title}</title>
</head>
<body>
 <header class="mainHeader">
    <a href="/" class="logo">
        <img src="https://res.cloudinary.com/du5e2crvt/image/upload/v1777023268/Captura_de_pantalla_2026-04-24_113406_y5pars.png"
         alta="blogLove"
         class="lovo-img"
         style="width: 230px; height: auto;" />
    </a>
    <nav class="site-nav">
     <a href="/" class="nav-link">Inicio</a>
     <a href="/about" class="nav-link">Quiénes somos</a>
    </nav>
 </header>
 <div class="header-waves" aria-hidden="true" data-astro-transition-persist="header-waves">
  <svg
    viewBox="0 23 200 24"
    preserveAspectRatio="none"
    xmlns="http://www.w3.org/2000/svg"
  >
   <defs>
      <path
        id="wave"
        d="M-160 44c30 0 58-18 88-18s58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z"
      />
    </defs>
    <g>
      <use href="#wave" x="48" y="0" fill="rgba(251,144,171,0.4)" />
      <use href="#wave" x="48" y="3" fill="rgba(251,144,171,0.25)" />
      <use href="#wave" x="48" y="6" fill="rgba(100, 52, 64, 0.15)" />
    </g>
  </svg>
  </div>
 <h1 class="page-title">{title}</h1>
 <slot />
 <script>
  window.addEventListener("scroll", () => {
    const header = document.querySelector(".mainHeader");
    if (window.scrollY > 50) {
      header.classList.add("scrolled");
    } else {
      header.classList.remove("scrolled");
    }
  });
</script>
</body>
</html>

<style>

.mainHeader {
  display: flex;
  justify-content: center;
  padding: 20px;
  position: sticky;
  top: 0;
  background: white;
  z-index: 100;
  transition: justify-content 0.5s ease;
}

.logo {
  transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  transform: translateX(0);
}

.site-nav {
  display: flex;
  gap: 20px;
  position: absolute;
  left: 30px;
  top: 50%;
  transform: translateY(-50%);
  transition: top 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
  transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.mainHeader.scrolled .logo {
  transform: translateX(calc(-50vw + 130px));
  }

.mainHeader.scrolled .logo .site-nav {
  top: calc(100% + 10px);   /* justo debajo del header */
  transform: translateY(0);
  left: 20px;
}

.nav-link {
  display: flex;
  gap: 20px;
  justify-content: center;
  text-decoration: none;
  font-family: Georgia, serif;
  font-size: 18px;
  font-weight: 400;
  line-height: 1.4;
  background: linear-gradient(to bottom, #342f2f, #fb90ab);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.page-title {
  text-align: center;
  font-family: Georgia, serif;
  font-size: 25px;
  font-weight: 400;
  margin: 8px 0 6px;
  line-height: 1.4;
  color: #080808;
}

.header-waves {
    position: sticky;        /* se queda pegado justo debajo del header */
    top: 80px;               /* ajusta según la altura real del header */
    left: 0;
    right: 0;
    height: 20px;
    overflow: hidden;
    pointer-events: none;
    z-index: 101;
  }

  .header-waves svg {
  display: block;
  width: 100%;
  height: 100%;
}

.header-waves g use:nth-child(1) {
  animation: wave-move 6s linear infinite;
}
.header-waves g use:nth-child(2) {
  animation: wave-move 9s linear infinite reverse;
}
.header-waves g use:nth-child(3) {
  animation: wave-move 12s linear infinite;
}

@keyframes wave-move {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
</style>