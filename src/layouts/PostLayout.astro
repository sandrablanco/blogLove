---
const {subtitle, date, category} = Astro.props
---
<article class="post-card">
<span class="post-category">{category}</span>
<h2 class="post-subtitle">{subtitle}</h2>
<p>{category}</p>
<time class="post-date">
<p>{date}</p>
</time>
<hr class="post-divider" />
<div class="post-content">
<slot />
</div>
</article>

<style>
<style>
.post-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 520px;
  margin: 40px auto;
  padding: 30px 33px;
  border-radius: 18px;
  border: 1px solid rgba(201, 81, 111, 0.12);
  box-shadow:
    0 2px 8px rgba(0, 0, 0, 0.04),
    0 8px 32px rgba(201, 81, 111, 0.07);
}

.post-category {
  font-size: 12px;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: #c9516f;
  font-family: Arial, sans-serif;
}

.post-subtitle {
  font-family: Georgia, serif;
  font-size: 20px;
  font-weight: 400;
  margin: 8px 0 6px;
  line-height: 1.4;
  text-align: center;
  background: linear-gradient(to bottom, #1a1a1a, #fb90ab);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.post-date {
  font-size: 11px;
  color: #bbb;
  font-family: Arial, sans-serif;
  margin-bottom: 16px;
}

.post-divider {
  width: 100%;
  border: none;
  border-top: 1px solid rgba(201, 81, 111, 0.15);
  margin-bottom: 20px;
}

.post-content {
  font-family: Georgia, serif;
  font-size: 15px;
  line-height: 1.8;
  color: #1a1a1a;
  text-align: justify;
  width: 100%;
  boder: 1px solid rgba(201, 81, 111, 0.2);
  border-radius: 12px;
  box-shadow:
    0 2px 8px rgba(0, 0, 0, 0.04),
    0 8px 32px rgba(201, 81, 111, 0.07);
  padding: 20px 24px;
}
</style>