---
import MainLayout from "../layouts/MainLayout.astro"
import {getCollection, type CollectionEntry} from "astro:content";
const posts: CollectionEntry<"blog">[] = await getCollection ("blog");

const latest = posts.sort((a: CollectionEntry<"blog">, b:CollectionEntry<"blog">) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 5);
const categories = [...new Set(posts.map((p: CollectionEntry<"blog">) => p.data.category))];
const getPostSlug = (id: string) => id.replace (".mdx", "").replace(".md", "");

---

<MainLayout title="Home">
<section>
<h2>Últimos posts</h2>
<ul>
{latest.map((post: CollectionEntry<"blog">) => (
    <li>
    <a href={`/blog/${getPostSlug(post.id)}`}>
    <p>{post.data.title}</p>
    </a>
    </li>
))}</ul>
</section>
<p>Bienvenidos a las páginas que te servirán de refugio y desahogo</p>
</MainLayout>